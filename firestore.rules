rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Admin validation (mocked for simplicity, assuming a dedicated admin collection)
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }

    // Validation Blueprints
    function isValidRestaurant(data) {
      return data.keys().hasAll(['name', 'location']) &&
             data.name is string && data.name.size() <= 100 &&
             data.location is string && data.location.size() <= 100 &&
             (!('reviewsCount' in data) || data.reviewsCount is number) &&
             (!('rating' in data) || data.rating is number) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10)) &&
             (!('isAiPick' in data) || data.isAiPick is bool) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidTrend(data) {
      return data.keys().hasAll(['restaurantId', 'name', 'reason']) &&
             data.restaurantId is string && data.restaurantId.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.reason is string && data.reason.size() <= 200 &&
             (!('trendDirection' in data) || (data.trendDirection is string && data.trendDirection in ['up', 'stable', 'down'])) &&
             (!('score' in data) || data.score is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /restaurants/{restaurantId} {
      allow read: if true; // Publicly readable dashboard
      allow create: if isAdmin() && isValidId(restaurantId) && isValidRestaurant(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(restaurantId) && isValidRestaurant(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(restaurantId);
    }

    match /trends/{trendId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(trendId) && isValidTrend(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(trendId) && isValidTrend(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(trendId);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable from Firebase Console
    }
  }
}
