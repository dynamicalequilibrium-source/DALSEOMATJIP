rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── 식당 컬렉션 (크롤러 + 에이전트가 쓰고, 앱이 읽는다) ──────────────
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(restaurantId);
      allow update: if isAdmin() && isValidId(restaurantId);
      allow delete: if isAdmin();
    }

    // ── 트렌드 컬렉션 ────────────────────────────────────────────────────────
    match /trends/{trendId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(trendId);
      allow delete: if isAdmin();
    }

    // ── AI 브리핑 (날짜별 1개) ──────────────────────────────────────────────
    match /briefings/{date} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── 어드민 ──────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
